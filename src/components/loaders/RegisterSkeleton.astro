---

---

<div class='flex w-full animate-pulse flex-col gap-6'>
  {/* Selected Vehicle Summary Skeleton */}
  <div
    class='bg-gray/10 flex min-h-[160px] flex-col items-center gap-4 rounded-xl p-4 shadow-sm md:flex-row'
  >
    <div class='h-32 w-52 shrink-0 rounded-lg bg-gray-200'></div>
    <div class='flex w-full flex-1 flex-col gap-2 md:items-end'>
      <div class='h-8 w-3/4 rounded bg-gray-200 md:w-1/2'></div>
      <div class='mt-2 flex flex-wrap justify-center gap-x-6 gap-y-2 md:justify-end'>
        <div class='h-4 w-24 rounded bg-gray-200'></div>
        <div class='h-4 w-24 rounded bg-gray-200'></div>
        <div class='h-4 w-24 rounded bg-gray-200'></div>
        <div class='h-4 w-24 rounded bg-gray-200'></div>
      </div>
    </div>
  </div>

  <div class='flex flex-col gap-4 lg:flex-row'>
    {/* Left Column - Information Sections (Arrival, Return, Passenger) */}
    <div class='left flex w-full flex-col gap-8'>
      {
        [1, 2, 3].map((i) => (
          <div class='space-y-6 rounded-2xl bg-white px-4 py-6 shadow-xl'>
            <div class='mb-6 h-6 w-1/3 rounded bg-gray-200' />
            <div class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4'>
              {[1, 2, 3, 4].map((j) => (
                <div class='space-y-2'>
                  <div class='h-4 w-24 rounded bg-gray-200' />
                  <div class='h-10 w-full rounded border border-gray-200 bg-gray-100' />
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    {/* Right Column - Booking Summary, Payment Methods, Submission */}
    <div class='right flex w-full flex-col gap-4 lg:max-w-sm'>
      {/* Booking Summary Skeleton */}
      <div
        class='flex items-center justify-between rounded-lg bg-black/80 p-4 shadow-md'
      >
        <div class='flex w-full flex-col items-center justify-center gap-2'>
          <div class='h-6 w-1/2 rounded bg-gray-700'></div>
          <div class='flex items-center gap-2'>
            <div class='h-4 w-4 rounded bg-gray-700'></div>
            <div class='h-4 w-32 rounded bg-gray-700'></div>
          </div>
        </div>
      </div>

      {/* Payment Method Skeleton */}
      <div class='space-y-6 rounded-2xl bg-white px-4 py-6 shadow-xl'>
        <div class='mb-6 h-6 w-1/3 rounded bg-gray-200'></div>
        <div class='flex flex-col gap-4'>
          {[1, 2, 3].map((i) => (
            <div class='h-16 w-full rounded-xl border border-gray-200 bg-gray-50' />
          ))}
        </div>
      </div>

      {/* Booking Submission Skeleton */}
      <div class='mt-6 flex flex-col items-center gap-4'>
        <div class='h-4 w-full rounded bg-gray-200'></div>
        <div class='h-16 w-full rounded-lg bg-gray-300'></div>
      </div>
    </div>
  </div>
</div>
